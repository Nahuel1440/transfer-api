generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id      String @id @default(uuid())
  name    String
  email   String @unique
  balance Int    @default(0)

  outgoingTransactions Transaction[] @relation("OriginTransactions")
  incomingTransactions Transaction[] @relation("DestinationTransactions")
  ledgerEntries        LedgerEntry[]

  createdAt DateTime @default(now())
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Transaction {
  id     String @id @default(uuid())
  amount Int

  originId      String
  destinationId String

  origin      User @relation("OriginTransactions", fields: [originId], references: [id])
  destination User @relation("DestinationTransactions", fields: [destinationId], references: [id])

  status TransactionStatus @default(PENDING)

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([originId, createdAt])
  @@index([destinationId, createdAt])
}

model LedgerEntry {
  id           String @id @default(uuid())
  amount       Int
  balanceAfter Int

  userId        String
  transactionId String

  user        User        @relation(fields: [userId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([transactionId])
}
